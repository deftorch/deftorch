# ==============================================
# Genesis - Environment Variables
# ==============================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control!

# ⚠️  PENTING: Jangan pernah menggunakan prefix NEXT_PUBLIC_ untuk API keys.
#    Prefix tersebut akan mengekspos key ke browser dan bisa dicuri siapa saja.

# ================================================================
# AI PROVIDER API KEYS — SERVER SIDE ONLY (jangan pakai NEXT_PUBLIC_)
# Nilai ini TIDAK dikirim ke browser.
# ================================================================

# Google Gemini API Key (WAJIB)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: multiple keys for rotation (numbered sequentially)
# GEMINI_API_KEY_1=
# GEMINI_API_KEY_2=

# Optional AI providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Google Cloud (optional, for advanced features)
# GOOGLE_CLOUD_API_KEY=
# GOOGLE_CLOUD_PROJECT_ID=

# ----------------------------------------------
# App Configuration
# ----------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_NAME="Genesis"
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ----------------------------------------------
# Supabase (auth + database + image storage)
# NOTE: URL & anon key MUST use the NEXT_PUBLIC_ prefix — the code reads
# process.env.NEXT_PUBLIC_SUPABASE_URL / NEXT_PUBLIC_SUPABASE_ANON_KEY
# (lib/supabaseClient.ts, app/api/upload-image/route.ts). The old
# unprefixed SUPABASE_URL/SUPABASE_ANON_KEY names below were never
# actually read by any code — fixed as part of Fase C.
# ----------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — SERVER ONLY, never prefix with NEXT_PUBLIC_.
# Used by app/api/migrate/route.ts and app/api/upload-media/*/route.ts
# to write on the user's behalf after verifying their access token
# (bypasses RLS, so never expose this).
# SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------
# Cloudflare R2 (Fase D — multi-modal upload: video/audio/document)
# One-time bucket/CORS/lifecycle setup can't be done from code — see
# R2_SETUP.md for the manual dashboard/wrangler steps.
# ----------------------------------------------
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=deftorch-media

# ----------------------------------------------
# Image Cleanup Authorization
# ----------------------------------------------
# Generate with: openssl rand -hex 32
# Also authorizes app/api/cleanup-media/route.ts (Fase D) — same token,
# both crons check it the same timing-safe way.
CRON_TOKEN=your_cron_token_here

# ----------------------------------------------
# Optional: Redis (for rate limiting in multi-instance deployment)
# ----------------------------------------------
# REDIS_URL=redis://localhost:6379
